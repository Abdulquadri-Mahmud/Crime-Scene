# Copy this file to .env and fill in real values. Never commit .env to source control.

# Server
PORT=5000
NODE_ENV=development

# MongoDB Atlas connection string (free M0 cluster works fine)
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/crime_reporting_db

# JWT secrets - use long random strings in production
JWT_ACCESS_SECRET=replace_this_with_a_long_random_string
JWT_REFRESH_SECRET=replace_this_with_a_different_long_random_string
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# CORS - the deployed frontend origin
CLIENT_URL=http://localhost:3000

# Optional: Cloudinary for evidence file uploads (leave blank to use local /uploads folder)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Optional: email notifications (e.g. using Gmail SMTP or SendGrid)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
NOTIFICATION_FROM_EMAIL=no-reply@communitycrimereport.local
